{
    "runOnSave.commands": [
        {
            "globMatch": "quarto/**/_*.qmd",
            "command": "touch ${workspaceFolder}/quarto/textbook.qmd",
            "runIn": "backend",
            "runningStatusMessage": "Refreshing Quarto preview...",
            "finishStatusMessage": "Preview refreshed"
        }
    ]
}