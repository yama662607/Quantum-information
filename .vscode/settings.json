{
    "runOnSave.commands": [
        {
            "globMatch": "quarto/**/_*.qmd",
            "command": "echo ' ' >> ${workspaceFolder}/quarto/textbook.qmd && sed -i '' '$d' ${workspaceFolder}/quarto/textbook.qmd",
            "runIn": "backend",
            "runningStatusMessage": "Forcing Quarto preview refresh...",
            "finishStatusMessage": "Preview refreshed"
        }
    ]
}