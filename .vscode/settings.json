{
    "runOnSave.commands": [
        {
            "globMatch": "quarto/**/_*.qmd",
            "command": "echo ' ' >> ${workspaceFolder}/quarto/textbook.qmd && sleep 1 && sed -i '' '$d' ${workspaceFolder}/quarto/textbook.qmd",
            "runIn": "backend",
            "runningStatusMessage": "Refreshing Quarto preview (with delay)...",
            "finishStatusMessage": "Preview refreshed"
        }
    ]
}